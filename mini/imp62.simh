set debug stdout

do impconfig.simh
set imp num=62
do impcode.simh

set mi1 enabled
set hi1 enabled
set hi2 enabled
set hi1 debug
set hi2 debug

attach -u mi1 4461::4442
attach -u hi1 22101:localhost:22102
SET MI2 ENABLED
attach -u mi2 4462::4451

attach -u hi2 22103:localhost:22104
set hi2 convert

go
